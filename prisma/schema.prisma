
generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  BUYER
  AGENT
  ADMIN
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND 
  COMMERCIAL
}

enum ListingType {
    SALE
    RENT
}

enum ViewingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}


// Model Creation

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  hashedPassword String
  role           Role     @default(BUYER)
  phone          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt()

  agentProfile   AgentProfile?
  saved          SavedProperty[]
  buyerViewings  Viewing[] @relation("buyer")
  agentViewings  Viewing[] @relation("agent")
  
  @@index([email])
  @@index([role])
}

model AgentProfile {
  id String @id @default(uuid())
  userId String @unique
  agency String
  licenseNumber String
  bio String?
  rating Float @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  properties Property[]
}

model Property {
  id String @id @default(uuid())
  agentId String
  title String
  description String
  price Float
  type ListingType
  propertyType PropertyType
  bedrooms Int
  bathrooms Int
  area Float
  address String
  city String
  isApproved Boolean @default(false)
  isFeatured Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
  
  agent AgentProfile @relation(fields: [agentId], references: [id], onDelete: Cascade)
  images PropertyImage[]
  saved SavedProperty[]
  viewings Viewing[]

  @@index([agentId])
  @@index([city])
  @@index([isApproved])
}

model PropertyImage {
  id String @id @default(ulid())
  propertyId String
  imageUrl String
  isPrimary Boolean @default(false)
  order Int
  filename String
  size Int
  mimeType String
  createdAt DateTime @default(now())
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model SavedProperty {
  id String @id @default(ulid())
  userId String
  propertyId String
  savedAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@unique([userId, propertyId])
  @@index([userId])
}

model Viewing {
  id String @id @default(ulid())
  propertyId String
  buyerId String
  agentId String
  scheduledAt DateTime
  status ViewingStatus @default(PENDING)
  notes String?
  createdAt DateTime @default(now())
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buyer User @relation("buyer", fields: [buyerId], references: [id], onDelete: Cascade)
  agent User @relation("agent", fields: [agentId], references: [id], onDelete: Cascade)
}